# Frontend Environment Variables
# Create a .env file in the frontend directory

# Backend API URL
VITE_API_URL=http://localhost:8000
VITE_API_URL=https://your-backend-app-name.railway.app
# For production deployment, use your deployed backend URL:
# VITE_API_URL=https://your-backend-app-name.railway.app
# VITE_API_URL=https://your-backend-app-name.onrender.com
# VITE_API_URL=https://your-backend-app-name.herokuapp.com

# Optional: Analytics and other third-party services
# REACT_APP_GOOGLE_ANALYTICS_ID=your_ga_id_here
# REACT_APP_SENTRY_DSN=your_sentry_dsn_here